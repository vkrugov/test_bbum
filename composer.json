{
    "name": "app/task-scheduler",
    "description": "PHP task scheduler application",
    "type": "project",
    "require": {
        "php": "^8.1",
        "predis/predis": "^2.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "optimize-autoloader": true
    },
    "minimum-stability": "stable"
}
